rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    // Itilizatè — li pou tout moun konekte, ekri sèlman pwòp pwofil
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && isOwner(uid);
    }

    // Rooms — tout moun konekte ka li ak kreye
    match /rooms/{roomId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();

      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000;
        // Sèlman pwopriyetè mesaj ka modifye
        allow update: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // Mesaj dirèk — sèlman patisipan yo
    match /direct/{convId} {
      allow read: if isAuth()
        && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000;
        allow update: if isAuth() && (
          resource.data.senderId == request.auth.uid
          || request.resource.data.keys().hasOnly(['seen'])
        );
      }
    }

    // Typing — sèlman moun konekte, li pou patisipan yo
    match /typing/{path} {
      allow read, write: if isAuth();
    }
  }
}
